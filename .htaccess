PassengerAppRoot /home/u371622571/domains/lightslategray-lyrebird-119144.hostingersite.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs22/root/bin/node
PassengerStartupFile server.js
PassengerBaseURI /
PassengerRestartDir /home/u371622571/domains/lightslategray-lyrebird-119144.hostingersite.com/nodejs/tmp
SetEnv NODE_OPTIONS "--require /home/u371622571/domains/lightslategray-lyrebird-119144.hostingersite.com/public_html/.builds/config/preload-timestamp.js"
SetEnv LSNODE_CONSOLE_LOG console.log

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Protect internal build files
  RewriteRule ^\.builds - [F,L]

  # If request has no extension and matching .html file exists, serve it
  RewriteCond %{REQUEST_URI} !\.[^/]+$
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Fallback to index.html for SPA routes
  RewriteRule ^ index.html [L]
</IfModule>
